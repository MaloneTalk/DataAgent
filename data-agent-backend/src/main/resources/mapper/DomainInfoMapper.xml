<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.malonetalk.mapper.DomainInfoMapper">

    <resultMap id="BaseResultMap" type="io.github.malonetalk.entity.DomainInfo">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM domain_info
        ORDER BY name ASC, id ASC
    </select>

    <select id="selectPage" resultMap="BaseResultMap">
        SELECT * FROM domain_info
        <where>
            <if test="query.keyword != null and query.keyword != ''">
                LOWER(name) LIKE CONCAT('%', LOWER(#{query.keyword}), '%')
            </if>
        </where>
        <choose>
            <when test="sortDescending">
                ORDER BY name DESC, id DESC
            </when>
            <otherwise>
                ORDER BY name ASC, id ASC
            </otherwise>
        </choose>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM domain_info
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByName" resultMap="BaseResultMap">
        SELECT * FROM domain_info
        WHERE LOWER(name) = LOWER(#{name})
        LIMIT 1
    </select>

    <insert id="insert" parameterType="io.github.malonetalk.entity.DomainInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO domain_info (
            name, description,
            create_time, update_time
        ) VALUES (
            #{name}, #{description},
            #{createTime}, #{updateTime}
        )
    </insert>

    <update id="update" parameterType="io.github.malonetalk.entity.DomainInfo">
        UPDATE domain_info
        <set>
            <if test="name != null">name = #{name},</if>
            description = #{description},
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        DELETE FROM domain_info
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
